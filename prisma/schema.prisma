generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Story {
  id          String       @id @default(cuid())
  title       String
  description String       @default("")
  category    String       @default("Сказки")
  ageRange    String       @default("3-6")
  coverImage  String       @default("")
  author      String       @default("Народная")
  duration    Int          @default(5)
  isFavorite  Boolean      @default(false)
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
  pages       StoryPage[]
}

model StoryPage {
  id               String   @id @default(cuid())
  storyId          String
  pageNumber       Int
  text             String
  illustrationUrl  String   @default("")
  illustrationPrompt String @default("")
  animationType    String   @default("fade")
  animationDuration Float   @default(1.0)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
  story            Story    @relation(fields: [storyId], references: [id], onDelete: Cascade)

  @@index([storyId])
}

model Settings {
  id         String @id @default(cuid())
  theme      String @default("warm")
  fontSize   String @default("large")
  autoPlay   Boolean @default(false)
  voiceSpeed Float  @default(1.0)
}
